{
  "global": {
    "price_sort": "asc",
    "tag_bonuses": {
      "新品": 5,
      "爆款": 4,
      "高毛利": 3,
      "现货": 2,
      "清仓": -3
    }
  },
  "categories": {
    "工业相机": {
      "param_schema": {
        "分辨率": {
          "column": "resolution_mp",
          "type": "numeric",
          "unit": "MP",
          "display_name": "分辨率",
          "hint": "统一换算为百万像素(MP)，4K≈8.3MP，1200万=12MP"
        },
        "帧率": {
          "column": "frame_rate",
          "type": "numeric",
          "unit": "fps",
          "display_name": "帧率"
        },
        "接口类型": {
          "column": "interface",
          "type": "enum",
          "unit": "",
          "display_name": "接口类型",
          "options": ["USB3.0", "GigE", "Camera Link", "CoaXPress"]
        },
        "感光元件": {
          "column": "sensor_type",
          "type": "enum",
          "unit": "",
          "display_name": "感光元件",
          "options": ["CMOS", "CCD"]
        },
        "快门类型": {
          "column": "shutter_type",
          "type": "enum",
          "unit": "",
          "display_name": "快门类型",
          "options": ["全局", "卷帘", "滚动"]
        },
        "色彩模式": {
          "column": "color_mode",
          "type": "enum",
          "unit": "",
          "display_name": "色彩模式",
          "options": ["彩色", "黑白"]
        },
        "最低工作温度": {
          "column": "temp_min",
          "type": "numeric",
          "unit": "℃",
          "display_name": "最低工作温度"
        },
        "最高工作温度": {
          "column": "temp_max",
          "type": "numeric",
          "unit": "℃",
          "display_name": "最高工作温度"
        },
        "防护等级": {
          "column": "protection_level",
          "type": "enum",
          "unit": "",
          "display_name": "防护等级",
          "options": ["IP40", "IP54", "IP67", "IP68"]
        },
        "像素尺寸": {
          "column": "pixel_size_um",
          "type": "numeric",
          "unit": "μm",
          "display_name": "像素尺寸"
        },
        "价格": {
          "column": "price",
          "type": "numeric",
          "unit": "元",
          "display_name": "价格"
        }
      },
      "special_specs": ["interface", "shutter_type", "protection_level"],
      "important_specs": {
        "resolution_mp": {"weight": 0.35, "display_name": "分辨率", "preference": ">="},
        "frame_rate":    {"weight": 0.30, "display_name": "帧率",   "preference": ">="},
        "pixel_size_um": {"weight": 0.20, "display_name": "像素尺寸", "preference": "any"},
        "temp_min":      {"weight": 0.15, "display_name": "最低工作温度", "preference": "<="}
      }
    },

