    "网络摄像机": {
      "param_schema": {
        "分辨率": {
          "column": "resolution_mp",
          "type": "numeric",
          "unit": "MP",
          "display_name": "分辨率",
          "hint": "换算为百万像素：400万=4MP，200万=2MP，1080P≈2MP，4K≈8MP"
        },
        "最高帧率": {
          "column": "frame_rate",
          "type": "numeric",
          "unit": "fps",
          "display_name": "最高帧率"
        },
        "传感器尺寸": {
          "column": "sensor_size",
          "type": "enum",
          "unit": "",
          "display_name": "传感器尺寸",
          "options": ["1/1.8\"", "1/2.0\"", "1/2.8\"", "1/3.0\""]
        },
        "焦距": {
          "column": "focal_length_mm",
          "type": "numeric",
          "unit": "mm",
          "display_name": "焦距"
        },
        "补光类型": {
          "column": "ir_mode",
          "type": "enum",
          "unit": "",
          "display_name": "补光类型",
          "options": ["红外", "暖光", "无"]
        },
        "补光距离": {
          "column": "ir_range_m",
          "type": "numeric",
          "unit": "m",
          "display_name": "补光距离"
        },
        "最低照度": {
          "column": "min_illumination_lux",
          "type": "numeric",
          "unit": "lux",
          "display_name": "最低照度",
          "hint": "值越小越好，全彩可达0.0005lux，红外0.01lux"
        },
        "视频编码": {
          "column": "compression",
          "type": "enum",
          "unit": "",
          "display_name": "视频编码",
          "options": ["超级265", "H.265", "H.264", "MJPEG"]
        },
