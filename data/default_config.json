          "column": "protection_level",
          "type": "enum",
          "unit": "",
          "display_name": "防护等级",
          "options": ["IP67", "IP66", "IP65", "IP54"]
        },
        "供电方式": {
          "column": "power_supply",
          "type": "enum",
          "unit": "",
          "display_name": "供电方式",
          "options": ["DC12V/PoE", "DC12V", "PoE"]
        },
        "最低工作温度": {
          "column": "temp_min",
          "type": "numeric",
          "unit": "℃",
          "display_name": "最低工作温度"
        },
        "最高工作温度": {
          "column": "temp_max",
          "type": "numeric",
          "unit": "℃",
          "display_name": "最高工作温度"
        },
        "价格": {
          "column": "price",
          "type": "numeric",
          "unit": "元",
          "display_name": "价格"
        }
      },
      "special_specs": ["ir_mode", "protection_level", "power_supply"],
      "important_specs": {
        "resolution_mp": {"weight": 0.40, "display_name": "分辨率",   "preference": ">="},
        "ir_range_m":    {"weight": 0.30, "display_name": "补光距离", "preference": ">="},
        "frame_rate":    {"weight": 0.30, "display_name": "最高帧率", "preference": ">="}
      }
